# Snowflake Configuration
SNOWFLAKE_ACCOUNT=your_account.region
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_WAREHOUSE=your_warehouse
SNOWFLAKE_DATABASE=your_database
SNOWFLAKE_SCHEMA=your_schema
SNOWFLAKE_ROLE=your_role

# Snowflake Cortex AI Configuration
CORTEX_AI_MODEL=claude-4-sonnet
CORTEX_AI_ENDPOINT=your_cortex_endpoint

# Application Configuration
APP_NAME=Snowflake AI Assistant
APP_VERSION=1.0.0
LOG_LEVEL=INFO
DEBUG=False

# LangChain Configuration
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langchain_api_key
LANGCHAIN_PROJECT=snowflake-ai-assistant

# Optional: OpenAI API Key (if using OpenAI models as fallback)
OPENAI_API_KEY=your_openai_api_key

# Streamlit Configuration
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0

